# ============================================================
# Studio Portfolio — Environment Variables
# ============================================================

# API server URL (build time — used for SSR/prerender)
# Development: http://localhost:3001
# Production:  http://your-server-ip:3001
API_URL=http://localhost:3001

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studio
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Secret (required in production)
JWT_SECRET=your-secret-key-change-me

# Upload directory (absolute path)
UPLOAD_DIR=./server/uploads

# API port
API_PORT=3001
